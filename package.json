{
  "name": "leetcode-mega-project",
  "version": "1.0.0",
  "description": "A full-stack LeetCode-like platform",
  "private": true,
  "scripts": {
    "dev": "npm --prefix ./backend install && npm --prefix ./frontend install && npm --prefix ./frontend run dev",
    "dev:backend": "npm --prefix ./backend run dev",
    "dev:frontend": "npm --prefix ./frontend run dev",
    "install:all": "npm --prefix ./backend install && npm --prefix ./frontend install",
    "build": "npm --prefix ./frontend run build",
    "lint": "npm --prefix ./frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "daisyui": "^5.5.19"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.14.0",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  }
}
